      "name": "content_prompt_in_extra",
      "reason": "a prompt under a provider namespace in extra is rejected content",
      "request": {
        "schema_version": 2,
        "events": [
          {
            "schema_version": 2,
            "event_id": "conf:extra_prompt",
            "event_kind": "attempt",
            "finality": "final",
            "sequence": 1,
            "provider": "anthropic",
            "native_model": "claude-sonnet-4-5",
            "ts_started": "2026-07-10T12:00:00Z",
            "source": {
              "type": "gateway",
              "name": "aiProviderProxy",
              "version": "1.4.0"
            },
            "success": true,
            "outcome": "success",
            "input_tokens": 10,
            "output_tokens": 5,
            "extra": {
              "anthropic": {
                "prompt": "user secret"
              }
            }
          }
        ]
      },
      "expected_status": 422,
      "expected_errors": [
        {
          "index": 0,
          "code": "content_key",
          "field_path_contains": "prompt"
        }
      ]
    },
