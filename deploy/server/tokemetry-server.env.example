# Native systemd environment file for the tokemetry server.
# Install to /etc/tokemetry/server.env, chmod 0600, chown tokemetry:tokemetry.
# Never commit the real file. All settings are TOKEMETRY_-prefixed; see
# apps/server/src/tokemetry_server/config.py for the full list.

# Address and port uvicorn binds to. Use the WireGuard address so the API is
# never exposed on a public interface.
TOKEMETRY_BIND_HOST=10.10.0.1
TOKEMETRY_BIND_PORT=8787

# Database. SQLite (below) is the simplest native option; for Postgres use
# postgresql+asyncpg://user:pass@host/db instead.
TOKEMETRY_DATABASE_URL=sqlite+aiosqlite:////var/lib/tokemetry/tokemetry.sqlite3

# Run schema migrations automatically on startup.
TOKEMETRY_AUTO_MIGRATE=true

# Serve the built dashboard SPA. Build it once (npm --prefix apps/dashboard run
# build) and point this at the output directory.
TOKEMETRY_STATIC_DIR=/opt/tokemetry/apps/dashboard/dist

# Bootstrap bearer token for first-run collector setup and minting real tokens
# through the API. Use a long random string.
TOKEMETRY_API_BOOTSTRAP_TOKEN=tkm_change_me

# Optional: monthly subscription price for the "value multiple" metric.
TOKEMETRY_SUBSCRIPTION_MONTHLY_USD=200

# Optional alert channels (or configure them in the dashboard Alerts page,
# which stores them in the database and takes precedence over these).
# TOKEMETRY_NTFY_TOPIC=
# TOKEMETRY_TELEGRAM_BOT_TOKEN=
# TOKEMETRY_TELEGRAM_CHAT_ID=
