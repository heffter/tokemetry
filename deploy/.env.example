# tokemetry server (Docker Compose) environment.
# Copy to deploy/.env and fill in the values, then run:
#   docker compose up -d --build
# Never commit the real .env; it holds secrets. All variables below are read
# by deploy/docker-compose.yml.

# WireGuard address the server port is published on. The API and dashboard are
# reachable ONLY on this address (e.g. http://10.10.0.1:8787), never on the
# public interface. Leave as 127.0.0.1 for a local-only test.
WG_ADDRESS=10.10.0.1

# Postgres credentials. POSTGRES_PASSWORD is required and has no default; use a
# long random string. POSTGRES_USER/POSTGRES_DB default to "tokemetry".
POSTGRES_USER=tokemetry
POSTGRES_PASSWORD=change_me_to_a_long_random_password
POSTGRES_DB=tokemetry

# First-run/admin bearer token. Collectors use it for their first upload, and
# it mints per-client tokens through the dashboard Settings view. Use a long
# random string; keep it for administration once real tokens exist.
TOKEMETRY_API_BOOTSTRAP_TOKEN=tkm_change_me_to_a_long_random_token

# Optional: monthly subscription price, shown as the "value multiple" metric.
TOKEMETRY_SUBSCRIPTION_MONTHLY_USD=200

# Row retention worker. Disabled by default: usage rows are kept indefinitely
# and only backup files age out. Set true to enforce the per-category retention
# policy (180-day raw events, etc.). See docs/architecture/retention.md.
TOKEMETRY_RETENTION_WORKER_ENABLED=false

# Optional: ntfy topic for alerts (or configure channels in the dashboard).
TOKEMETRY_NTFY_TOPIC=
