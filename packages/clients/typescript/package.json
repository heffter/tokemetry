{
  "name": "@tokemetry/client",
  "version": "0.1.0",
  "description": "TypeScript client for the tokemetry v2 ingest API (proxy exporters).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate": "openapi-typescript ../openapi.json -o src/generated.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
